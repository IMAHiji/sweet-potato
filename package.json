{
  "name": "sweet-potato",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "concurrently -n vite,server -c cyan,yellow \"pnpm dev:client\" \"pnpm dev:server\"",
    "dev:client": "vite",
    "dev:server": "tsx watch --env-file=.env src/server/index.ts",
    "build": "vite build && tsc -p tsconfig.json && node scripts/copy-server-assets.mjs",
    "start": "node dist/server/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:zhuyin": "vitest run tests/zhuyin.test.ts",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.client.json --noEmit",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write .",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx --env-file=.env src/server/db/migrate.ts",
    "db:studio": "drizzle-kit studio",
    "seed:dev": "tsx --env-file=.env scripts/seed-dev.ts",
    "data:download": "tsx scripts/download-data.ts",
    "seed": "tsx --env-file=.env scripts/seed.ts",
    "codegraph": "tsx scripts/codegraph.ts"
  },
  "devDependencies": {
    "@types/alpinejs": "^3.13.11",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^26.0.1",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "@vitest/coverage-v8": "^4.1.9",
    "concurrently": "^10.0.3",
    "drizzle-kit": "^0.31.10",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "jsdom": "^29.1.1",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.4",
    "sass": "^1.101.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "@fastify/autoload": "^6.3.1",
    "@fastify/cookie": "^11.0.2",
    "@fastify/formbody": "^8.0.2",
    "@fastify/rate-limit": "^11.0.0",
    "@fastify/secure-session": "^8.3.0",
    "@fastify/static": "^9.1.3",
    "@fastify/view": "^12.0.0",
    "alpinejs": "^3.15.12",
    "better-sqlite3": "^12.11.1",
    "drizzle-orm": "^0.45.2",
    "eta": "^4.6.0",
    "fastify": "^5.8.5",
    "fastify-plugin": "^6.0.0",
    "zod": "^4.4.3"
  }
}
