# Copy to .env and fill in real values. Never commit .env.

# Path to the SQLite database file. The directory is created on startup if it
# does not exist. In production, point this at a mounted persistent disk.
DATABASE_PATH=./data/sweet-potato.db

# Key for @fastify/secure-session sealed cookies. Must be >= 32 bytes.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=replace-with-at-least-32-bytes-of-random-hex

# Seeded admin login (full access).
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-admin

# Seeded non-admin test user (study only).
TEST_USER_EMAIL=user@example.com
TEST_USER_PASSWORD=change-me-user

# HSK level range to seed (inclusive). Default 1-3.
HSK_LEVELS=1-3

# HTTP port.
PORT=3000

# development | production
NODE_ENV=development
