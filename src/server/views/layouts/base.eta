<!doctype html>
<html lang="zh-TW" data-theme="sunny">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= it.title ?? '地瓜' %></title>
  <!-- No-FOUC theme script -->
  <script>
    (function() {
      var t = localStorage.getItem('theme');
      if (!t) t = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'sunny';
      document.documentElement.dataset.theme = t;
    })();
  </script>
  <% if (it.styleUrl) { %>
  <link rel="stylesheet" href="<%= it.styleUrl %>" />
  <% } %>
</head>
<body x-data>
  <%~ include('/partials/nav', it) %>
  <main class="container">
    <%~ include('/partials/flash', it) %>
    <%~ it.body %>
  </main>
  <footer style="text-align:center;padding:2rem;color:var(--text-muted);font-size:0.875rem;">
    地瓜 · Chinese character study
  </footer>
  <% if (it.scriptUrl) { %>
  <% if (it.NODE_ENV === 'development') { %>
  <script type="module" src="http://localhost:5173/@vite/client"></script>
  <script type="module" src="<%= it.scriptUrl %>"></script>
  <% } else { %>
  <script type="module" src="<%= it.scriptUrl %>"></script>
  <% } %>
  <% } %>
</body>
</html>
