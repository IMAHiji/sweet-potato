<section class="card card--pad-lg center stack">
  <div style="font-size: var(--fs-2xl)">😵‍💫</div>
  <h1><%= it.status || 500 %> · <%= it.title || 'Something went wrong' %></h1>
  <p class="muted"><%= it.message || 'An unexpected error occurred.' %></p>
  <div class="cluster" style="justify-content: center">
    <a class="btn btn--primary" href="/">Back home</a>
  </div>
</section>
