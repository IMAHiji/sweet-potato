# Dependencies
node_modules/
.pnp
.pnp.js
.pnpm-store/

# Build output
dist/
public/
*.tsbuildinfo

# Environment / secrets
.env
.env.*
!.env.example

# Downloaded source data (HSK list, MOEDICT, CC-CEDICT) — regenerated by scripts/download-data.ts
scripts/data/

# SQLite database (created at runtime / by the seed) and its WAL/SHM sidecars.
# Keep the directory itself (drizzle-kit migrate won't create it) but ignore
# its contents.
data/*
!data/.gitkeep
*.db
*.db-wal
*.db-shm

# Logs
*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*

# Caches
.cache/
.vite/
coverage/

# Editor / OS
.DS_Store
Thumbs.db
.idea/
.vscode/*
!.vscode/extensions.json
*.swp
